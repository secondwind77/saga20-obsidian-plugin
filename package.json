    "builtin-modules": "^3.3.0",
    "esbuild": "0.17.3",
    "eslint": "^8.57.1",
    "eslint-plugin-obsidianmd": "^0.2.9",
    "obsidian": "latest",
    "tslib": "^2.4.0",
    "typescript": "^4.9.4"
